model ServiceRequest {
  id          String   @id @default(cuid())
  requesterId String?
  requester   Profile? @relation(fields: [requesterId], references: [id], onDelete: SetNull)
  category    String
  city        String
  budget      String?
  message     String?
  status      String   @default("requested")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([requesterId])
  @@index([category])
  @@index([status])
}

model ServiceProvider {
  id           String   @id @default(cuid())
  profileId    String?
  businessName String
  category     String
  city         String?
  rating       Decimal  @default(0)
  verified     Boolean  @default(false)
  priceLabel   String?
  createdAt    DateTime @default(now())

  @@index([profileId])
  @@index([category])
  @@index([verified])
}

model BuilderProject {
  id             String   @id @default(cuid())
  builderId      String?
  builder        Profile? @relation(fields: [builderId], references: [id], onDelete: SetNull)
  name           String
  city           String
  locality       String?
  description    String?
  unitsCount     Int?
  availableUnits Int?
  mediaUrls      String[] @default([])
  campaignStatus String   @default("draft")
  aiReport       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([builderId])
}

