model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model OtpChallenge {
  id         String    @id @default(cuid())
  userId     String?
  phone      String
  codeHash   String
  purpose    String    @default("PHONE_VERIFICATION")
  attempts   Int       @default(0)
  consumedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([phone])
  @@index([phone, purpose])
  @@index([expiresAt])
}
